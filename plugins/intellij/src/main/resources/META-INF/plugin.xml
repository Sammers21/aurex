<idea-plugin>
  <id>dev.aurex.ide</id>
  <name>Aurex</name>
  <vendor>Aurex</vendor>
  <description>Aurex init, build, run, and ax.toml navigation actions.</description>

  <depends>com.intellij.modules.platform</depends>

  <extensions defaultExtensionNs="com.intellij">
    <notificationGroup id="Aurex" displayType="BALLOON"/>
  </extensions>

  <actions>
    <group id="Aurex.Actions" text="Aurex" popup="true">
      <add-to-group group-id="ToolsMenu" anchor="last"/>
      <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>

      <action id="Aurex.Init"
              class="dev.aurex.intellij.actions.InitAurexProjectAction"
              text="Init Aurex Project"
              description="Run ax init"/>
      <action id="Aurex.Build"
              class="dev.aurex.intellij.actions.BuildAurexProjectAction"
              text="Build Aurex Project"
              description="Run ax build"/>
      <action id="Aurex.Run"
              class="dev.aurex.intellij.actions.RunAurexProjectAction"
              text="Run Aurex Project"
              description="Run ax run"/>
      <separator/>
      <action id="Aurex.OpenToml"
              class="dev.aurex.intellij.actions.OpenAurexTomlAction"
              text="Open ax.toml"
              description="Open the Aurex project config"/>
    </group>
  </actions>
</idea-plugin>
