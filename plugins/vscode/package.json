{
  "name": "aurex-vscode",
  "displayName": "Aurex",
  "description": "VS Code helpers for Aurex Java build system projects.",
  "version": "0.1.0",
  "publisher": "aurex",
  "license": "Apache-2.0",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:ax.toml",
    "onCommand:aurex.initProject",
    "onCommand:aurex.build",
    "onCommand:aurex.run",
    "onCommand:aurex.test",
    "onCommand:aurex.clean",
    "onCommand:aurex.format",
    "onCommand:aurex.openManifest"
  ],
  "main": "./src/extension.js",
  "scripts": {
    "test": "node --check src/extension.js && node --check src/aurexProjects.js && node --test test/aurexProjects.test.js"
  },
  "contributes": {
    "commands": [
      {
        "command": "aurex.initProject",
        "title": "Aurex: Init Project",
        "category": "Aurex",
        "icon": "$(new-folder)"
      },
      {
        "command": "aurex.build",
        "title": "Aurex: Build",
        "category": "Aurex",
        "icon": "$(tools)"
      },
      {
        "command": "aurex.run",
        "title": "Aurex: Run",
        "category": "Aurex",
        "icon": "$(run)"
      },
      {
        "command": "aurex.test",
        "title": "Aurex: Test",
        "category": "Aurex",
        "icon": "$(beaker)"
      },
      {
        "command": "aurex.clean",
        "title": "Aurex: Clean",
        "category": "Aurex",
        "icon": "$(trash)"
      },
      {
        "command": "aurex.format",
        "title": "Aurex: Format",
        "category": "Aurex",
        "icon": "$(symbol-color)"
      },
      {
        "command": "aurex.openManifest",
        "title": "Aurex: Open ax.toml",
        "category": "Aurex",
        "icon": "$(go-to-file)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "aurex.initProject"
        },
        {
          "command": "aurex.build",
          "when": "workspaceFolderCount > 0"
        },
        {
          "command": "aurex.run",
          "when": "workspaceFolderCount > 0"
        },
        {
          "command": "aurex.test",
          "when": "workspaceFolderCount > 0"
        },
        {
          "command": "aurex.clean",
          "when": "workspaceFolderCount > 0"
        },
        {
          "command": "aurex.format",
          "when": "workspaceFolderCount > 0"
        },
        {
          "command": "aurex.openManifest",
          "when": "workspaceFolderCount > 0"
        }
      ],
      "explorer/context": [
        {
          "command": "aurex.initProject",
          "when": "explorerResourceIsFolder",
          "group": "aurex@1"
        },
        {
          "command": "aurex.build",
          "group": "aurex@2"
        },
        {
          "command": "aurex.run",
          "group": "aurex@3"
        },
        {
          "command": "aurex.test",
          "group": "aurex@4"
        },
        {
          "command": "aurex.clean",
          "group": "aurex@5"
        },
        {
          "command": "aurex.format",
          "group": "aurex@6"
        },
        {
          "command": "aurex.openManifest",
          "group": "aurex@7"
        }
      ],
      "editor/title": [
        {
          "command": "aurex.build",
          "when": "resourceFilename == ax.toml",
          "group": "navigation@1"
        },
        {
          "command": "aurex.run",
          "when": "resourceFilename == ax.toml",
          "group": "navigation@2"
        },
        {
          "command": "aurex.test",
          "when": "resourceFilename == ax.toml",
          "group": "navigation@3"
        },
        {
          "command": "aurex.format",
          "when": "resourceFilename == ax.toml",
          "group": "navigation@4"
        }
      ]
    },
    "configuration": {
      "title": "Aurex",
      "properties": {
        "aurex.executablePath": {
          "type": "string",
          "default": "ax",
          "description": "Path or command name for the Aurex executable."
        },
        "aurex.revealTerminal": {
          "type": "boolean",
          "default": true,
          "description": "Reveal the task terminal when running Aurex commands."
        }
      }
    },
    "configurationDefaults": {
      "files.associations": {
        "ax.toml": "toml"
      }
    },
    "snippets": [
      {
        "language": "toml",
        "path": "./snippets/ax-toml.code-snippets"
      }
    ],
    "taskDefinitions": [
      {
        "type": "aurex",
        "required": [
          "command"
        ],
        "properties": {
          "command": {
            "type": "string",
            "enum": [
              "init",
              "build",
              "run",
              "test",
              "clean",
              "fmt"
            ]
          },
          "cwd": {
            "type": "string",
            "description": "Aurex project root for this task."
          },
          "executable": {
            "type": "string",
            "description": "Aurex executable path or command name."
          }
        }
      }
    ]
  }
}
